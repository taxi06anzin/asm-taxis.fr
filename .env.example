# ===== Variables d'environnement ASM Taxis =====
# Copie ce fichier en ".env" pour le dev local : cp .env.example .env
# Les variables préfixées PUBLIC_ sont exposées au navigateur (Astro).
# ⚠️ Ne mets JAMAIS de secret/clé privée dans une variable PUBLIC_.

# ID du conteneur Google Tag Manager (mesure d'audience, chargé après consentement).
# Laisse la valeur du compte ASM Taxis, ou remplace par le tien.
PUBLIC_GTM_ID=GTM-W3SBRBL9

# Clé API Geoapify (autocomplétion d'adresses + itinéraire routier du calculateur de prix).
# Clé côté navigateur — à restreindre au domaine asm-taxis.fr dans la console Geoapify.
# Obtenir une clé gratuite : https://myprojects.geoapify.com
PUBLIC_GEOAPIFY_KEY=votre_cle_geoapify
