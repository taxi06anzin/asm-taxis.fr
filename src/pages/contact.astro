---
import Base from "../layouts/Base.astro";
import WhatsAppForm from "../components/WhatsAppForm.astro";
import { site, localBusinessNode, breadcrumbNode } from "../data/site";

const path = "/contact/";
const title = "Contact ASM Taxis Lille | Téléphone & WhatsApp 24h/24";
const description =
  "Contactez ASM Taxis à Lille : téléphone 06 42 98 85 78, WhatsApp, e-mail. Artisan taxi ADS n°180 à Loos, métropole lilloise. Disponible 24h/24, 7j/7.";

const schema = [
  localBusinessNode({}),
  breadcrumbNode([{ name: "Accueil", path: "/" }, { name: "Contact", path }]),
];
---

<Base title={title} description={description} path={path} schema={schema}>
  <section class="bg-ink text-white py-12">
    <div class="container mx-auto px-4 max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-3">Contacter ASM Taxis</h1>
      <p class="text-neutral-300">Un taxi à Lille, 24h/24. Le plus rapide reste l'appel téléphonique.</p>
    </div>
  </section>

  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 max-w-5xl grid md:grid-cols-2 gap-10">
      <div>
        <h2 class="text-2xl font-extrabold mb-6">Coordonnées</h2>
        <ul class="space-y-4 text-neutral-700">
          <li><span class="font-bold">Téléphone :</span> <a href={site.phoneHref} class="text-ink underline hover:text-taxi font-bold">{site.phone}</a></li>
          <li><span class="font-bold">WhatsApp :</span> <a href={`https://wa.me/${site.whatsapp}`} target="_blank" rel="noopener" class="text-ink underline hover:text-taxi">Écrire un message</a></li>
          <li><span class="font-bold">E-mail :</span> <a href={`mailto:${site.email}`} class="text-ink underline hover:text-taxi">{site.email}</a></li>
          <li><span class="font-bold">Exploitant :</span> ASM TAXI (SASU)</li>
          <li><span class="font-bold">Autorisation :</span> ADS Lille n°{site.ads}</li>
          <li><span class="font-bold">Secteur :</span> {site.address.locality} ({site.address.postalCode}) — {site.zone}</li>
          <li><span class="font-bold">Horaires :</span> 7j/7, 24h/24</li>
          <li><a href={site.googleProfile} target="_blank" rel="noopener noreferrer" class="text-taxi font-bold hover:underline">Voir notre fiche Google →</a></li>
        </ul>
        <div class="mt-8 bg-cream border-l-4 border-taxi p-5 rounded-r-xl">
          <p class="text-sm text-neutral-700">Pour une prise en charge immédiate, privilégiez l'appel. Le formulaire et WhatsApp conviennent parfaitement aux réservations à l'avance.</p>
        </div>
      </div>
      <div>
        <WhatsAppForm heading="Envoyer une demande" />
      </div>
    </div>
  </section>

  <section class="pb-14 bg-white">
    <div class="container mx-auto px-4 max-w-5xl">
      <h2 class="text-2xl font-extrabold mb-4">Notre secteur</h2>
      <div class="rounded-2xl overflow-hidden border border-neutral-200 shadow-sm">
        <iframe
          title="Zone desservie par ASM Taxis — Lille et métropole lilloise"
          src="https://www.openstreetmap.org/export/embed.html?bbox=2.9300%2C50.5650%2C3.2200%2C50.7150&layer=mapnik&marker=50.60921%2C3.01625"
          width="100%"
          height="380"
          style="border:0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
      <p class="text-sm text-neutral-500 mt-3">
        Basés à {site.address.locality} ({site.address.postalCode}), nous desservons Lille et toute la métropole lilloise, 24h/24.
        <a href={site.googleProfile} target="_blank" rel="noopener noreferrer" class="text-ink font-bold underline hover:text-taxi ml-1">Itinéraire &amp; avis sur Google →</a>
      </p>
    </div>
  </section>

  <section class="pb-16 bg-white">
    <div class="container mx-auto px-4 max-w-5xl grid md:grid-cols-2 gap-6">
      <!-- Ajouter aux contacts (vCard) -->
      <div class="bg-cream rounded-2xl p-8 border border-neutral-100 flex flex-col">
        <h2 class="text-2xl font-extrabold mb-2">Gardez notre numéro à portée de main</h2>
        <p class="text-neutral-600 mb-6 flex-1">Enregistrez ASM Taxis dans vos contacts en un clic : vous nous rappelez directement à votre prochain trajet.</p>
        <a href="/asm-taxis.vcf" download class="inline-flex items-center justify-center gap-2 bg-ink text-white font-bold py-4 px-6 rounded-xl hover:bg-ink-soft transition-colors">
          📇 Enregistrer notre numéro
        </a>
      </div>
      <!-- Avis Google + QR -->
      <div class="bg-cream rounded-2xl p-8 border border-neutral-100">
        <h2 class="text-2xl font-extrabold mb-2">Votre avis compte</h2>
        <p class="text-neutral-600 mb-5">Vous avez voyagé avec nous ? Un avis nous aide énormément. Scannez le QR ou cliquez :</p>
        <div class="flex items-center gap-5">
          <img src="/assets/images/qr-avis-google.png" alt="QR code pour laisser un avis Google à ASM Taxis" width="120" height="120" loading="lazy" class="w-28 h-28 rounded-lg bg-white p-1 border border-neutral-200" />
          <a href={site.googleProfile} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-taxi hover:bg-taxi-dark text-ink font-bold py-3 px-5 rounded-xl transition-colors">
            ★ Laisser un avis Google
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
