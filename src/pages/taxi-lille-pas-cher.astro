---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import Faq from "../components/Faq.astro";
import CallCta from "../components/CallCta.astro";
import PriceCalculator from "../components/PriceCalculator.astro";
import { site, localBusinessNode, faqNode, breadcrumbNode } from "../data/site";
import { TARIFS } from "../data/tarifs";

const path = "/taxi-lille-pas-cher/";
const title = "Taxi Lille Pas Cher | Tarifs & Calculateur de Prix — ASM Taxis";
const description =
  "Taxi Lille : calculez le prix de votre course (distance réelle) et consultez le barème officiel 2026 de la préfecture du Nord. Tarif au compteur, sans majoration cachée. ☎ 06 42 98 85 78.";

const eur = (n: number) => n.toFixed(2).replace(".", ",") + " €";

// Barème kilométrique officiel (arrêté préfectoral du Nord 2026)
const km = [
  ["A", "Aller-retour avec le client (retour en charge) — jour, 7h–19h hors dimanche/férié", TARIFS.km.A],
  ["B", "Aller-retour avec le client (retour en charge) — nuit 19h–7h, ou dimanche/jour férié", TARIFS.km.B],
  ["C", "Aller simple (un trajet avec le client, l'autre à vide) — jour, 7h–19h", TARIFS.km.C],
  ["D", "Aller simple (un trajet avec le client, l'autre à vide) — nuit 19h–7h, ou dimanche/jour férié", TARIFS.km.D],
] as const;

const faq = [
  { q: "Comment fonctionne le calculateur de prix ?", a: "Il mesure la distance routière réelle entre votre départ et votre destination (pas à vol d'oiseau) via OpenStreetMap, puis applique le barème officiel de la préfecture du Nord : prise en charge, tarif kilométrique selon l'heure (jour/nuit, dimanche/férié), suppléments et minimum de perception. Le résultat est une estimation : le prix réel est celui affiché au compteur (trafic, attente, itinéraire effectif)." },
  { q: "Le prix change-t-il la nuit, le dimanche ou les jours fériés ?", a: "Oui, comme pour tous les taxis : le tarif de nuit (19h–7h), du dimanche et des jours fériés est majoré (tarifs B/D au lieu de A/C). Si une course chevauche 19h, le calculateur répartit le trajet entre tarif jour et tarif nuit." },
  { q: "Pourquoi parler de taxi « pas cher » si les tarifs sont réglementés ?", a: "Les tarifs d'un taxi sont fixés par arrêté préfectoral : ils sont les mêmes pour tous les artisans. « Pas cher » avec ASM Taxis signifie : aucun supplément abusif, pas de tarification dynamique (surge), un compteur honnête, une estimation claire à l'avance et la possibilité d'une remise commerciale sur le montant du compteur." },
  { q: "Puis-je connaître le prix de ma course avant de partir ?", a: `Le prix exact d'un taxi est celui affiché au compteur en fin de course : la loi interdit au chauffeur d'inventer un forfait. Nous pouvons toutefois vous donner une <strong>estimation précise</strong> à l'avance (calculateur ci-dessus ou par téléphone) et garantir un <strong>prix maximum</strong> — si le compteur dépasse ce plafond, nous appliquons une remise. Appelez le ${site.phone} pour une estimation gratuite.` },
  { q: "Le taxi est-il moins cher qu'un VTC à Lille ?", a: "Cela dépend du moment. Contrairement aux VTC, le taxi ne pratique pas de tarification dynamique : aux heures de pointe, la nuit ou lors d'événements, le prix d'un taxi reste celui du compteur officiel, sans flambée soudaine." },
  { q: "Comment payer ma course ?", a: "En carte bancaire ou en espèces, directement à bord. Une note de taxi détaillée vous est remise sur demande, utile pour vos remboursements professionnels." },
  { q: "Proposez-vous un prix à l'avance pour l'aéroport et les gares ?", a: `Un taxi ne peut pas créer librement de forfait : le prix est celui du compteur (tarif préfectoral). Nous vous donnons une <strong>estimation précise</strong> à l'avance pour <a class="text-ink font-bold underline" href="/taxi-aeroport-lille/">l'aéroport</a>, les <a class="text-ink font-bold underline" href="/taxi-gare-lille-flandres/">gares</a>, Charleroi, Bruxelles ou la longue distance, avec un <strong>prix maximum garanti</strong> (remise si le compteur dépasse). Estimez votre course avec le calculateur ci-dessus.` },
];

const schema = [
  localBusinessNode({ priceRange: "€€" }),
  breadcrumbNode([{ name: "Accueil", path: "/" }, { name: "Taxi Lille pas cher", path }]),
  faqNode(faq),
];
---

<Base title={title} description={description} path={path} ogImage="/assets/images/vieux-lille.webp" schema={schema}>
  <PageHero
    eyebrow="Tarifs transparents"
    h1="Taxi Lille pas cher : des tarifs clairs"
    intro="Tarif officiel au compteur, sans majoration cachée ni tarification dynamique. Estimation précise à l'avance et prix maximum garanti — le compteur reste la référence, remise possible."
    image="/assets/images/vieux-lille.webp"
    imageAlt="Taxi Lille pas cher — Vieux-Lille, ASM Taxis"
    lcp={true}
  />

  <PriceCalculator />

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-extrabold mb-6">Le bon prix, sans mauvaise surprise</h2>
      <p class="text-neutral-700 leading-relaxed mb-6">
        Chez ASM Taxis, « pas cher » ne veut pas dire au rabais : cela veut dire <strong>juste et transparent</strong>. Les tarifs sont ceux fixés par l'arrêté préfectoral du Nord, identiques pour tous les taxis. Notre engagement : un compteur honnête, aucun supplément injustifié, et une <strong>estimation écrite à l'avance avec prix maximum garanti</strong> dès que vous le demandez.
      </p>

      <h3 class="text-xl font-bold mb-3">Barème officiel 2026 (préfecture du Nord)</h3>
      <div class="overflow-x-auto rounded-2xl border border-neutral-200 mb-6">
        <table class="w-full text-sm">
          <tbody class="divide-y divide-neutral-200">
            <tr class="hover:bg-cream"><td class="p-4 font-medium">Prise en charge</td><td class="p-4 font-bold text-ink whitespace-nowrap text-right">{eur(TARIFS.priseEnCharge)}</td></tr>
            <tr class="hover:bg-cream"><td class="p-4 font-medium">Minimum de perception (toute course, suppléments inclus)</td><td class="p-4 font-bold text-ink whitespace-nowrap text-right">{eur(TARIFS.minimum)}</td></tr>
            <tr class="hover:bg-cream"><td class="p-4 font-medium">Heure d'attente / marche au pas — jour (7h–19h)</td><td class="p-4 font-bold text-ink whitespace-nowrap text-right">{eur(TARIFS.attenteJour)}</td></tr>
            <tr class="hover:bg-cream"><td class="p-4 font-medium">Heure d'attente / marche au pas — nuit (19h–7h)</td><td class="p-4 font-bold text-ink whitespace-nowrap text-right">{eur(TARIFS.attenteNuit)}</td></tr>
            <tr class="hover:bg-cream"><td class="p-4 font-medium">Supplément bagage (4e+ ou encombrant)</td><td class="p-4 font-bold text-ink whitespace-nowrap text-right">{eur(TARIFS.supplementBagage)}</td></tr>
            <tr class="hover:bg-cream"><td class="p-4 font-medium">Supplément par personne (à partir de la 5e)</td><td class="p-4 font-bold text-ink whitespace-nowrap text-right">{eur(TARIFS.supplementPersonne)}</td></tr>
          </tbody>
        </table>
      </div>

      <h3 class="text-xl font-bold mb-3">Tarifs kilométriques</h3>
      <div class="overflow-x-auto rounded-2xl border border-neutral-200">
        <table class="w-full text-sm">
          <thead class="bg-ink text-white text-left">
            <tr><th class="p-4">Tarif</th><th class="p-4">Conditions</th><th class="p-4 text-right">€/km</th></tr>
          </thead>
          <tbody class="divide-y divide-neutral-200">
            {km.map(([code, cond, val]) => (
              <tr class="hover:bg-cream">
                <td class="p-4 font-bold text-taxi-dark">{code}</td>
                <td class="p-4 text-neutral-700">{cond}</td>
                <td class="p-4 font-bold text-ink whitespace-nowrap text-right">{eur(val)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-neutral-500 mt-3">
        Barème issu de l'arrêté préfectoral du Nord du 2 février 2026. Le compteur progresse par « chute » de {eur(TARIFS.chute)}. Les tarifs officiels sont affichés dans le véhicule. Un tarif neige-verglas spécial peut s'appliquer en cas de conditions hivernales (signalé par affichette).
      </p>

      <h3 class="text-xl font-bold mt-10 mb-3">3 façons de payer moins cher, sereinement</h3>
      <ul class="space-y-2 text-neutral-700">
        <li>✅ <strong>Demandez une estimation</strong> pour l'aéroport ou la longue distance : prix maximum connu d'avance, remise possible.</li>
        <li>✅ <strong>Réservez à l'avance</strong> pour optimiser le trajet et éviter l'attente facturée.</li>
        <li>✅ <strong>Partagez le trajet</strong> à plusieurs : le prix de la course est le même, divisé entre passagers.</li>
      </ul>
    </div>
  </section>

  <Faq items={faq} title="Tarifs taxi Lille : questions fréquentes" />

  <section class="py-16 bg-cream">
    <div class="container mx-auto px-4 max-w-3xl">
      <CallCta label="Obtenez votre devis gratuit" sub="Indiquez départ et destination : nous vous annonçons le prix avant de partir." />
    </div>
  </section>
</Base>
