---
interface Props {
  items: { q: string; a: string }[];
  title?: string;
}
const { items, title = "Questions fréquentes" } = Astro.props;
---
<section class="py-16 bg-white">
  <div class="container mx-auto px-4 max-w-3xl">
    <h2 class="text-2xl md:text-3xl font-extrabold mb-8 text-center">{title}</h2>
    <div class="divide-y divide-neutral-200 border border-neutral-200 rounded-2xl overflow-hidden">
      {items.map((item) => (
        <details class="group">
          <summary class="flex justify-between items-center gap-4 cursor-pointer p-5 font-bold hover:bg-cream list-none">
            <span>{item.q}</span>
            <span class="text-taxi text-2xl leading-none transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="px-5 pb-5 text-neutral-700 leading-relaxed" set:html={item.a} />
        </details>
      ))}
    </div>
  </div>
</section>
