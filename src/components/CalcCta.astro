---
// Bandeau d'incitation vers le calculateur de prix (maillage interne)
interface Props {
  title?: string;
  sub?: string;
  cta?: string;
}
const {
  title = "Combien coûtera votre course ?",
  sub = "Distance routière réelle + barème officiel du Nord : obtenez votre prix estimatif en 30 secondes.",
  cta = "Calculer le prix de ma course",
} = Astro.props;
---
<section class="py-12 bg-taxi">
  <div class="container mx-auto px-4 max-w-3xl text-center">
    <h2 class="text-2xl md:text-3xl font-extrabold text-ink mb-2">{title}</h2>
    <p class="text-ink/80 mb-6">{sub}</p>
    <a href="/taxi-lille-pas-cher/#calculateur" class="inline-flex items-center justify-center gap-2 bg-ink text-white font-bold py-4 px-8 rounded-xl hover:bg-ink-soft transition-colors">
      <span aria-hidden="true">🧮</span> {cta}
    </a>
  </div>
</section>
